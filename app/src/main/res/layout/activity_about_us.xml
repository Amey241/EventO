<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.evento.ShowEventList"
    android:layout_gravity="center_horizontal">

<RelativeLayout
    android:id="@+id/activity_about_us"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/btnbg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="About Us"
        app:titleTextColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/toolbar"
        android:layout_centerInParent="true"
        android:layout_marginTop="6dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="Welcome to Evento - Your Ultimate Event Planning Companion!"
            android:textColor="#283618"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:src="@drawable/splashimage" />

        <TextView
            android:layout_width="124dp"
            android:layout_height="35dp"
            android:layout_marginLeft="110dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_corner"
            android:elevation="16dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="WHO WE ARE"
            android:textColor="@color/beige"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="121dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_corner"
            android:elevation="16dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="We are a passionate team of event enthusiasts and tech innovators dedicated to revolutionizing the way you plan and experience events. Our app is designed to streamline the planning process, offering a one-stop solution for all your event management needs."
            android:textColor="@color/beige" />

        <TextView
            android:layout_width="124dp"
            android:layout_height="45dp"
            android:layout_marginLeft="110dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_brown"
            android:elevation="16dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="WHAT WE OFFER"
            android:textColor="#283618"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="91dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_brown"
            android:elevation="16dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="Our app boasts an intuitive and user-friendly interface, making it easy for both seasoned event planners and first-time organizers to navigate and utilize its powerful features."
            android:textColor="#283618" />

        <TextView
            android:layout_width="124dp"
            android:layout_height="35dp"
            android:layout_marginLeft="110dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_yellow"
            android:elevation="16dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="OUR VISION"
            android:textColor="#283618"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="91dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_yellow"
            android:elevation="16dp"
            android:fontFamily="@font/baskervville"
            android:gravity="center"
            android:text="We envision a world where every event is a masterpiece. Through innovation and dedication, we strive to empower individuals and businesses to create unforgettable moments that leave a lasting impact."
            android:textColor="#283618" />
    </LinearLayout>

</RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/white"
        app:headerLayout="@layout/navigation_header"
        app:menu="@menu/navigation_menu"
        android:visibility="visible" /> <!-- Initially set to gone -->

</androidx.drawerlayout.widget.DrawerLayout>
