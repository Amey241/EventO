<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.evento.CreateEvent"
    android:layout_gravity="center_horizontal">

<RelativeLayout
    android:id="@+id/activity_create_event"
    android:background="#606C38"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="22dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="Create Event"
        app:titleTextColor="@android:color/white" />

<ScrollView
    android:layout_below="@id/toolbar"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_centerHorizontal="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="699dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="196dp"
            android:layout_height="165dp"
            android:layout_marginBottom="1dp"
            android:src="@drawable/createeventlogo" />

        <EditText
            android:id="@+id/event_name"
            android:layout_width="334dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:background="@drawable/rounded_corner"
            android:elevation="16dp"
            android:fontFamily="@font/corben"
            android:hint="Enter your Event name here"
            android:textColorHint="#FEFAE0"
            android:textColor="@color/beige" />

        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/border"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#283618"
                android:padding="5dp"
                android:src="@drawable/loc" />

            <EditText
                android:id="@+id/add_loc"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginRight="10dp"
                android:background="#F4F4F2"
                android:fontFamily="@font/baskervville"
                android:gravity="center_vertical"
                android:hint="Add Venue"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/border"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#283618"
                android:padding="5dp"
                android:src="@drawable/descr" />

            <EditText
                android:id="@+id/add_desc"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginRight="10dp"
                android:background="@color/white"
                android:fontFamily="@font/baskervville"
                android:gravity="center_vertical"
                android:hint="Add Description"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/border"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#283618"
                android:padding="5dp"
                android:src="@drawable/calender" />

            <EditText
                android:id="@+id/add_date"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginRight="10dp"
                android:background="@color/white"
                android:editable="false"
                android:fontFamily="@font/baskervville"
                android:gravity="center_vertical"
                android:hint="Add Date"

                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/border"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#283618"
                android:padding="5dp"
                android:src="@drawable/rupee" />

            <EditText
                android:id="@+id/add_expense"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginRight="10dp"
                android:background="@color/white"
                android:fontFamily="@font/baskervville"
                android:gravity="center_vertical"
                android:hint="Expenses"
                android:inputType="phone"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <Spinner
            android:id="@+id/type1"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:background="@drawable/rounded_button"
            android:entries="@array/type"></Spinner>

        <EditText
            android:id="@+id/evn_pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:hint="enter event password"
            android:inputType="numberPassword|number"
            android:textColor="@color/black"
            android:visibility="gone" />

        <Button
            android:id="@+id/submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="20dp"
            android:background="@drawable/rounded_button"
            android:text="Submit"
            android:textColor="@color/black"


            />
    </LinearLayout>
</ScrollView>
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:visibility="gone"
        />


</RelativeLayout>
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/white"
        app:headerLayout="@layout/navigation_header"
        app:menu="@menu/navigation_menu"
        android:visibility="visible" /> <!-- Initially set to gone -->

</androidx.drawerlayout.widget.DrawerLayout>
